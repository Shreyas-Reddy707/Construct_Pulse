# ConstructPulse Backend — Environment Variables
# Copy this file to .env and fill in the values.

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/constructpulse
POSTGRES_PASSWORD=changeme

# ── Security ──────────────────────────────────────────────────────────────────
SECRET_KEY=your-very-secret-key-change-this-in-production

# ── Runtime ───────────────────────────────────────────────────────────────────
ENVIRONMENT=development
LOG_LEVEL=INFO

# ── Feature flags ─────────────────────────────────────────────────────────────
# Set to true to bypass Firebase auth in development
DEMO_AUTH=false
